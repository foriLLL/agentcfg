{
  "ui": {
    "theme": "system",
    "compactMode": false
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai/gpt-4.1-mini",
        "fallback": "local/fallback-model"
      }
    }
  },
  "models": {
    "providers": {
      "legacy": {
        "baseUrl": "https://legacy.example.test/v1",
        "apiKey": "legacy-placeholder",
        "runtime": {
          "timeoutMs": 30000
        }
      },
      "openai": {
        "baseUrl": "https://api.openai.com/v1",
        "apiKey": "sk-test-visible-openai",
        "models": [
          {
            "id": "gpt-4.1-mini",
            "contextWindow": 1047576,
            "contextTokens": 1047576,
            "maxTokens": 32768
          }
        ]
      }
    }
  },
  "gateway": {
    "reloadOnChange": false
  }
}
