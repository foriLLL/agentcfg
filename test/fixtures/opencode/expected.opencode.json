{
  "theme": "system",
  "model": "openai/gpt-4.1-mini",
  "tools": {
    "bash": true,
    "webfetch": false
  },
  "permissions": {
    "edit": "ask",
    "bash": {
      "npm test": "allow"
    }
  },
  "plugins": [
    "local-plugin"
  ],
  "commands": {
    "lint": "npm run lint"
  },
  "provider": {
    "openai": {
      "options": {
        "baseURL": "https://api.openai.com/v1",
        "apiKey": "sk-test-visible-openai"
      },
      "models": {
        "gpt-4.1-mini": {
          "reasoning": true,
          "limit": {
            "context": 1047576,
            "input": 1047576,
            "output": 32768
          }
        }
      },
      "name": "openai"
    }
  }
}
