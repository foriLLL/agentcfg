{
  // Existing OpenCode settings should survive structural normalization.
  "theme": "system",
  "model": "anthropic/claude-3-5-sonnet",
  "tools": {
    "bash": true,
    "webfetch": false,
  },
  "permissions": {
    "edit": "ask",
    "bash": {
      "npm test": "allow",
    },
  },
  "plugins": [
    "local-plugin",
  ],
  "commands": {
    "lint": "npm run lint",
  },
  "provider": {
    "openai": {
      "options": {
        "baseURL": "https://old.example.test/v1",
        "apiKey": "old-redacted",
      },
      "models": {
        "gpt-4.1-mini": {
          "reasoning": true,
        },
      },
    },
  },
}
